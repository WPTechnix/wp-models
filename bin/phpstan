#!/usr/bin/env bash
# Thin wrapper — runs phpstan inside the Docker dev container.
# Usage: ./bin/phpstan [<phpstan-args>]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_FILE="${SCRIPT_DIR}/../docker/docker-compose.yml"

# Default arguments if none provided
DEFAULT_ARGS=(--memory-limit=2G --error-format=table)


# Use passed arguments if any, otherwise default
ARGS=("${@:-$DEFAULT_ARGS}")

docker compose -f "${COMPOSE_FILE}" run --rm php \
  vendor/bin/phpstan analyse "${ARGS[@]}"