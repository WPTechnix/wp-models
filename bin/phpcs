#!/usr/bin/env bash
# Thin wrapper — runs phpcs inside the Docker dev container.
# Usage: ./bin/phpcs [<phpcs-args>]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_FILE="${SCRIPT_DIR}/../docker/docker-compose.yml"

# Default arguments if none provided
DEFAULT_ARGS="src --report=full"

# Use passed arguments if any, otherwise default
ARGS=("${@:-$DEFAULT_ARGS}")

docker compose -f "${COMPOSE_FILE}" run --rm php \
  vendor/bin/phpcs "${ARGS[@]}"