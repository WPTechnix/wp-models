#!/usr/bin/env bash
# Thin wrapper — runs php inside the Docker dev container.
# Usage: ./bin/php <php-args>
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_FILE="${SCRIPT_DIR}/../docker/docker-compose.yml"

docker compose -f "${COMPOSE_FILE}" run --rm php php "$@"
