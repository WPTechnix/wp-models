# ─── Default: normalise line endings to LF everywhere ────────────────────────
* text=auto eol=lf

# ─── Language hints for diffs and GitHub Linguist ────────────────────────────
*.php     text eol=lf diff=php
*.js      text eol=lf
*.ts      text eol=lf
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.xml     text eol=lf
*.md      text eol=lf
*.sh      text eol=lf
*.txt     text eol=lf
*.dist    text eol=lf
*.neon    text eol=lf

# ─── Binary files — never diff or mangle ─────────────────────────────────────
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.tar  binary
*.gz   binary

# ─── Composer export-ignore ───────────────────────────────────────────────────
# Files/dirs below are excluded from `composer install --prefer-dist` archives
# (i.e. what Packagist ships to end-users).
# Keep: src/, composer.json, README.md, CHANGELOG.md, LICENSE

/.github            export-ignore
/.husky             export-ignore
/bin                export-ignore
/docker             export-ignore
/tests              export-ignore
/build              export-ignore

/.commitlintrc.json export-ignore
/.editorconfig      export-ignore
/.gitattributes     export-ignore
/.gitignore         export-ignore

/phpcs.xml.dist     export-ignore
/phpstan.neon.dist  export-ignore
/phpunit.xml        export-ignore

/package.json       export-ignore
/package-lock.json  export-ignore
